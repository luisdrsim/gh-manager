_load_locale() {
  local lang
  lang="${GHM_LANG:-$(echo "${LC_ALL:-${LC_MESSAGES:-${LANG:-en}}}" \
    | sed 's/[_.].*$//' | tr '[:upper:]' '[:lower:]')}"
  case "$lang" in
    es) _locale_es ;;
    fr) _locale_fr ;;
    de) _locale_de ;;
    pt) _locale_pt ;;
    it) _locale_it ;;
    *)  _locale_en ;;
  esac
}

_load_locale

# ── UI helpers ────────────────────────────────────────────────
ok()     { echo -e "  ${GREEN}✅${RESET}  $*"; }
warn()   { echo -e "  ${YELLOW}⚠️  $*${RESET}"; }
err()    { echo -e "  ${RED}❌${RESET}  $*"; }
info()   { echo -e "  ${CYAN}ℹ️  $*${RESET}"; }
step()   { echo -e "  ${BLUE}👉${RESET}  $*"; }
secret() { echo -e "  ${MAGENTA}🔐${RESET}  $*"; }

print_separator() { echo -e "${DIM}  ──────────────────────────────────────────────${RESET}"; }

pause() {
  echo ""
  read -rp "  $(echo -e "${DIM}${L_PRESS_ENTER}${RESET}")" _
}

confirm() {
  local msg="${1:-}"
  echo ""
  read -rp "  $(echo -e "${YELLOW}❓${RESET} ${msg} [${L_CONFIRM_YN}]: ")" ans
  [[ "$ans" =~ ^[${L_CONFIRM_CHARS}]$ ]]
}

# ── Prerequisites ─────────────────────────────────────────────
check_gh() {
  if ! command -v gh &>/dev/null; then
    echo ""
    err "$L_GH_NOT_FOUND"
    info "$L_GH_INSTALL"
    echo ""
    exit 1
  fi
}

# ── Account data ──────────────────────────────────────────────
get_active_account() {
  gh auth status 2>&1 \
    | awk '
        /Active account: true/ { found=1; next }
        found && /Logged in to/ {
          gsub(/.*account /, ""); gsub(/ .*/, ""); print; found=0
        }
      ' | head -1
}

get_all_accounts() {
  gh auth status 2>&1 \
    | grep "Logged in to github.com account" \
    | sed 's/.*account \([^ ]*\).*/\1/'
}

get_account_count() {
  get_all_accounts | wc -l | tr -d ' '
}

get_token_scopes() {
  local user="$1"
  gh auth status --hostname github.com 2>&1 \
    | awk -v u="$user" '
        $0 ~ ("account " u) { found=1 }
        found && /Token scopes/ {
          gsub(/.*Token scopes: /, ""); print; found=0
        }
      '
}

# ── Headers ───────────────────────────────────────────────────
print_header() {
  clear
  local active count accounts_label
  active=$(get_active_account 2>/dev/null || echo "—")
  count=$(get_account_count 2>/dev/null || echo "0")
  [[ "$count" == "1" ]] && accounts_label="$L_ACCOUNTS_1" || accounts_label="$L_ACCOUNTS_N"

  echo ""
  echo -e "${BOLD}${BLUE}  🐙 gh-manager${RESET}  ${DIM}·  ${L_SUBTITLE}${RESET}"
  print_separator
  echo -e "  👤  ${L_ACTIVE_ACCOUNT}  ${BOLD}${GREEN}${active}${RESET}   ${DIM}(${count} ${accounts_label})${RESET}"
  print_separator
  echo ""
}

print_section_header() {
  local icon="$1" title="$2"
  clear
  echo ""
  echo -e "${BOLD}${BLUE}  🐙 gh-manager${RESET}  ${DIM}›  ${icon} ${title}${RESET}"
  print_separator
  echo ""
}

# ── Account picker ────────────────────────────────────────────
PICKED_ACCOUNT=""

pick_account() {
  local title="${1:-}"
  PICKED_ACCOUNT=""
  mapfile -t accounts < <(get_all_accounts)

  if [[ ${#accounts[@]} -eq 0 ]]; then
    warn "$L_QSTATUS_NO_AUTH"
    return 1
  fi

  local active
  active=$(get_active_account 2>/dev/null || echo "")

  echo -e "  ${BOLD}${title}${RESET}"
  echo ""

  local i=1
  for acc in "${accounts[@]}"; do
    if [[ "$acc" == "$active" ]]; then
      echo -e "    ${GREEN}${BOLD}$i)${RESET}  🟢  ${BOLD}$acc${RESET}  ${DIM}${L_ACTIVE_MARKER}${RESET}"
    else
      echo -e "    ${CYAN}$i)${RESET}  ⚪  $acc"
    fi
    ((i++))
  done
  echo -e "    ${DIM}0)  ${L_CANCEL_OPTION}${RESET}"
  echo ""

  local choice
  read -rp "  $(echo -e "${BOLD}${L_OPTION}${RESET} ")" choice

  if [[ "$choice" == "0" || -z "$choice" ]]; then
    return 1
  fi

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#accounts[@]} )); then
    err "$L_INVALID_OPTION"
    sleep 1
    return 1
  fi

  PICKED_ACCOUNT="${accounts[$((choice-1))]}"
}

# ─────────────────────────────────────────────────────────────
#  1. Detailed status
# ─────────────────────────────────────────────────────────────
show_status() {
  print_section_header "📊" "$L_STATUS_TITLE"

  local active
  active=$(get_active_account 2>/dev/null || echo "—")
  mapfile -t accounts < <(get_all_accounts)

  if [[ ${#accounts[@]} -eq 0 ]]; then
    warn "$L_STATUS_NO_ACCOUNTS"
    info "$L_STATUS_ADD_HINT"
    pause; return
  fi

  for acc in "${accounts[@]}"; do
    if [[ "$acc" == "$active" ]]; then
      echo -e "  ${GREEN}${BOLD}  🟢 $acc${RESET}  ${DIM}${L_ACTIVE_MARKER}${RESET}"
    else
      echo -e "  ⚪  ${BOLD}$acc${RESET}"
    fi
    local scopes
    scopes=$(get_token_scopes "$acc" 2>/dev/null || echo "—")
    echo -e "${DIM}       ${L_STATUS_SCOPES} ${scopes}${RESET}"
    echo ""
  done

  print_separator
  echo ""
  info "$L_STATUS_FULL_OUTPUT"
  echo ""
  gh auth status 2>&1 | sed 's/^/    /'
  echo ""
  pause
}

# ─────────────────────────────────────────────────────────────
#  2. Switch account
# ─────────────────────────────────────────────────────────────
switch_account() {
  local target="${1:-}"
  print_section_header "🔄" "$L_SWITCH_TITLE"

  local active
  active=$(get_active_account 2>/dev/null || echo "")

  if [[ -n "$target" ]]; then
    mapfile -t all < <(get_all_accounts)
    local found=0
    for acc in "${all[@]}"; do [[ "$acc" == "$target" ]] && found=1 && break; done
    if [[ $found -eq 0 ]]; then
      err "$(printf "$L_SWITCH_NOT_FOUND" "${BOLD}$target${RESET}")"
      echo ""
      info "$L_SWITCH_AVAILABLE"
      for acc in "${all[@]}"; do echo "    • $acc"; done
      pause; return
    fi
    if [[ "$target" == "$active" ]]; then
      warn "$(printf "$L_SWITCH_ALREADY_ACTIVE" "${BOLD}$target${RESET}")"
      pause; return
    fi
    step "$(printf "$L_SWITCH_ACTIVATING" "${BOLD}$target${RESET}")"
    if gh auth switch --user "$target" &>/dev/null; then
      echo ""
      ok "$(printf "$L_SWITCH_SUCCESS" "${BOLD}${GREEN}$target${RESET}")"
    else
      err "$L_SWITCH_ERROR"
    fi
    pause; return
  fi

  if ! pick_account "$L_SWITCH_PICK"; then
    info "$L_CANCELLED"; sleep 1; return
  fi

  if [[ "$PICKED_ACCOUNT" == "$active" ]]; then
    warn "$(printf "$L_SWITCH_ALREADY_ACTIVE" "${BOLD}$PICKED_ACCOUNT${RESET}")"
    pause; return
  fi

  echo ""
  step "$(printf "$L_SWITCH_ACTIVATING" "${BOLD}$PICKED_ACCOUNT${RESET}")"
  if gh auth switch --user "$PICKED_ACCOUNT" &>/dev/null; then
    echo ""
    ok "$(printf "$L_SWITCH_SUCCESS" "${BOLD}${GREEN}$PICKED_ACCOUNT${RESET}")"
  else
    err "$L_SWITCH_ERROR"
  fi
  pause
}

# ─────────────────────────────────────────────────────────────
#  3. Add account
# ─────────────────────────────────────────────────────────────
add_account() {
  print_section_header "➕" "$L_ADD_TITLE"

  info "$L_ADD_INFO_1"
  info "$L_ADD_INFO_2"
  echo ""
  warn "$L_ADD_WARN_1"
  echo "       $L_ADD_WARN_2"
  echo ""

  confirm "$L_ADD_CONFIRM" || { info "$L_CANCELLED"; pause; return; }

  echo ""
  print_separator
  echo ""
  gh auth login --hostname github.com
  echo ""
  print_separator
  echo ""
  ok "$L_ADD_COMPLETE"
  echo ""
  info "$L_ADD_NOW_AUTH"
  echo ""
  mapfile -t accounts < <(get_all_accounts)
  for acc in "${accounts[@]}"; do echo "    🐙 $acc"; done
  pause
}

# ─────────────────────────────────────────────────────────────
#  4. Logout
# ─────────────────────────────────────────────────────────────
logout_account() {
  print_section_header "🚪" "$L_LOGOUT_TITLE"

  if ! pick_account "$L_LOGOUT_PICK"; then
    info "$L_CANCELLED"; sleep 1; return
  fi

  local active
  active=$(get_active_account 2>/dev/null || echo "")

  echo ""
  if [[ "$PICKED_ACCOUNT" == "$active" ]]; then
    warn "$(printf "$L_LOGOUT_WARN_ACTIVE" "${BOLD}$PICKED_ACCOUNT${RESET}")"
    info "$L_LOGOUT_WARN_ACTIVE_2"
  fi

  confirm "$(printf "$L_LOGOUT_CONFIRM" "${BOLD}$PICKED_ACCOUNT${RESET}")" \
    || { info "$L_CANCELLED"; pause; return; }

  echo ""
  step "$(printf "$L_LOGOUT_LOGGING_OUT" "${BOLD}$PICKED_ACCOUNT${RESET}")"
  if gh auth logout --hostname github.com --user "$PICKED_ACCOUNT" 2>&1 | sed 's/^/  /'; then
    echo ""
    ok "$(printf "$L_LOGOUT_SUCCESS" "${BOLD}$PICKED_ACCOUNT${RESET}")"
  else
    err "$L_LOGOUT_ERROR"
  fi
  pause
}

# ─────────────────────────────────────────────────────────────
#  5. Token
# ─────────────────────────────────────────────────────────────
show_token() {
  print_section_header "🔑" "$L_TOKEN_TITLE"

  if ! pick_account "$L_TOKEN_PICK"; then
    info "$L_CANCELLED"; sleep 1; return
  fi

  echo ""
  secret "$L_TOKEN_SENSITIVE"
  echo ""
  print_separator
  echo ""

  local token
  token=$(gh auth token --user "$PICKED_ACCOUNT" 2>&1)

  echo -e "  👤  ${BOLD}${L_TOKEN_ACCOUNT}${RESET}  $PICKED_ACCOUNT"
  echo -e "  🔑  ${BOLD}${L_TOKEN_TOKEN}${RESET}   ${DIM}${token}${RESET}"
  echo ""
  print_separator
  echo ""

  if command -v pbcopy &>/dev/null; then
    confirm "$L_TOKEN_COPY" && {
      echo -n "$token" | pbcopy
      echo ""
      ok "$L_TOKEN_COPIED"
    }
  fi
  pause
}

# ─────────────────────────────────────────────────────────────
#  6. Refresh auth
# ─────────────────────────────────────────────────────────────
refresh_auth() {
  print_section_header "🔁" "$L_REFRESH_TITLE"

  info "$L_REFRESH_INFO"
  echo ""

  mapfile -t accounts < <(get_all_accounts)

  if [[ ${#accounts[@]} -eq 0 ]]; then
    warn "$L_REFRESH_NO_ACCOUNTS"
    pause; return
  fi

  local all_ok=true
  for acc in "${accounts[@]}"; do
    echo -ne "  🔍  $(printf "$L_REFRESH_CHECKING" "${BOLD}$acc${RESET}")"
    if gh api user --hostname github.com \
         -H "Authorization: token $(gh auth token --user "$acc" 2>/dev/null)" \
         &>/dev/null 2>&1; then
      echo -e "  ${GREEN}✅ ${L_REFRESH_VALID}${RESET}"
    else
      echo -e "  ${RED}❌ ${L_REFRESH_INVALID}${RESET}"
      all_ok=false
      echo ""
      confirm "$(printf "$L_REFRESH_REAUTH" "${BOLD}$acc${RESET}")" && {
        echo ""
        gh auth login --hostname github.com
      }
    fi
  done

  echo ""
  $all_ok && ok "$L_REFRESH_ALL_OK" || warn "$L_REFRESH_SOME_WARN"
  pause
}

# ─────────────────────────────────────────────────────────────
#  7. Set .envrc
# ─────────────────────────────────────────────────────────────
set_envrc() {
  print_section_header "📁" "$L_ENVRC_TITLE"

  local cwd
  cwd=$(pwd)

  info "$L_ENVRC_INFO_1"
  info "$L_ENVRC_INFO_2"
  echo ""
  echo -e "  📂  ${L_ENVRC_CWD}  ${BOLD}${cwd}${RESET}"
  echo ""

  if ! pick_account "$L_ENVRC_PICK"; then
    info "$L_CANCELLED"; sleep 1; return
  fi

  local envrc_file="${cwd}/.envrc"

  if [[ -f "$envrc_file" ]]; then
    sed -i '' '/^export GH_USER=/d' "$envrc_file" 2>/dev/null \
      || sed -i '/^export GH_USER=/d' "$envrc_file"
    info "$L_ENVRC_UPDATING"
  else
    info "$L_ENVRC_CREATING"
  fi

  echo "export GH_USER=$PICKED_ACCOUNT" >> "$envrc_file"
  echo ""
  ok "$(printf "$L_ENVRC_OK" "$PICKED_ACCOUNT")"

  if command -v direnv &>/dev/null; then
    echo ""
    step "$L_ENVRC_DIRENV_RUN"
    direnv allow . 2>&1 | sed 's/^/  /' || true
    echo ""
    ok "$L_ENVRC_DIRENV_OK"
  else
    echo ""
    warn "$L_ENVRC_DIRENV_WARN"
    info "$L_ENVRC_DIRENV_INSTALL"
    info "$L_ENVRC_DIRENV_HOOK"
  fi
  pause
}

# ─────────────────────────────────────────────────────────────
#  Quick status
# ─────────────────────────────────────────────────────────────
show_quick_status() {
  local active
  active=$(get_active_account 2>/dev/null || echo "")

  echo ""
  echo -e "${BOLD}${BLUE}  ${L_QSTATUS_TITLE}${RESET}"
  print_separator

  if [[ -z "$active" ]]; then
    warn "$L_QSTATUS_NO_AUTH"
    echo ""; exit 1
  fi

  echo -e "  👤  ${BOLD}${L_QSTATUS_ACTIVE}${RESET}  ${GREEN}${BOLD}${active}${RESET}"
  echo ""
  echo -e "  ${BOLD}${L_QSTATUS_ALL}${RESET}"
  mapfile -t accounts < <(get_all_accounts)
  for acc in "${accounts[@]}"; do
    if [[ "$acc" == "$active" ]]; then
      echo -e "    ${GREEN}●${RESET}  ${BOLD}$acc${RESET}  ${DIM}${L_ACTIVE_MARKER}${RESET}"
    else
      echo -e "    ${DIM}○${RESET}  $acc"
    fi
  done
  echo ""
  print_separator
  echo ""
}

# ─────────────────────────────────────────────────────────────
#  Help
# ─────────────────────────────────────────────────────────────
show_help() {
  echo ""
  echo -e "${BOLD}${BLUE}  🐙 gh-manager${RESET}  ${DIM}·  ${L_SUBTITLE}${RESET}"
  print_separator
  echo ""
  echo -e "  ${BOLD}${L_HELP_USAGE}${RESET}"
  echo ""
  echo "    ghm                    →  $L_HELP_MENU"
  echo "    ghm status             →  $L_HELP_STATUS"
  echo "    ghm switch             →  $L_HELP_SWITCH"
  echo "    ghm switch <user>      →  $L_HELP_SWITCH_USER"
  echo "    ghm version            →  $L_HELP_VERSION"
  echo "    ghm help               →  $L_HELP_HELP"
  echo ""
  echo -e "  ${DIM}GHM_LANG=en|es|fr|de|pt|it  →  $L_HELP_LANG${RESET}"
  echo ""
  print_separator
  echo ""
}

# ─────────────────────────────────────────────────────────────
#  Main menu
# ─────────────────────────────────────────────────────────────
main_menu() {
  while true; do
    print_header

    echo -e "  ${BOLD}${L_MENU_WHAT}${RESET}"
    echo ""
    echo -e "  ${DIM}${L_MENU_SECTION_ACCOUNTS}${RESET}"
    echo "    1)  📊  $L_MENU_1"
    echo "    2)  🔄  $L_MENU_2"
    echo "    3)  ➕  $L_MENU_3"
    echo "    4)  🚪  $L_MENU_4"
    echo ""
    echo -e "  ${DIM}${L_MENU_SECTION_TOOLS}${RESET}"
    echo "    5)  🔑  $L_MENU_5"
    echo "    6)  🔁  $L_MENU_6"
    echo "    7)  📁  $L_MENU_7"
    echo ""
    print_separator
    echo "    0)  👋  $L_MENU_0"
    echo ""
    print_separator
    echo ""

    local option
    read -rp "  $(echo -e "${BOLD}${L_OPTION}${RESET} ")" option

    case "$option" in
      1) show_status ;;
      2) switch_account ;;
      3) add_account ;;
      4) logout_account ;;
      5) show_token ;;
      6) refresh_auth ;;
      7) set_envrc ;;
      0)
        echo ""
        echo -e "  👋  ${BOLD}${L_GOODBYE}${RESET}"
        echo ""
        exit 0
        ;;
      *)
        warn "$L_MENU_INVALID"
        sleep 1
        ;;
    esac
  done
}

# ─────────────────────────────────────────────────────────────
#  Entry point
# ─────────────────────────────────────────────────────────────
check_gh

case "${1:-}" in
  status)             show_quick_status ;;
  switch)             switch_account "${2:-}" ;;
  version|--version|-v) echo "ghm v${GHM_VERSION}" ;;
  help|--help|-h)     show_help ;;
  "")                 main_menu ;;
  *)
    err "$(printf "$L_UNKNOWN_CMD" "${BOLD}$1${RESET}")"
    show_help
    exit 1
    ;;
esac
