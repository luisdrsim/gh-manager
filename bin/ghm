#!/usr/bin/env bash
# gh-manager — GitHub account manager
#
# Usage:
#   ghm                  → interactive menu
#   ghm status           → quick status
#   ghm switch           → switch active account
#   ghm switch <user>    → switch directly
#   ghm help             → help
#
# Language: set GHM_LANG=en|es|fr|de|pt|it (default: auto-detect from $LANG)

set -euo pipefail

GHM_VERSION="1.0.0"

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Locales ───────────────────────────────────────────────────

_locale_en() {
  L_SUBTITLE="GitHub CLI · Account Manager"
  L_ACTIVE_ACCOUNT="Active account:"
  L_ACCOUNTS_1="account authenticated"
  L_ACCOUNTS_N="accounts authenticated"
  L_PRESS_ENTER="Press Enter to return to the menu..."
  L_CONFIRM_YN="y/N"; L_CONFIRM_CHARS="yY"
  L_OPTION="Option:"
  L_CANCELLED="Cancelled."
  L_INVALID_OPTION="Invalid option."
  L_MENU_INVALID="Invalid option. Choose between 0 and 7."
  L_ACTIVE_MARKER="← active"
  L_CANCEL_OPTION="↩️  Cancel"
  L_GH_NOT_FOUND="Command ${BOLD}gh${RESET} not found."
  L_GH_INSTALL="Install it with:  ${BOLD}brew install gh${RESET}"
  L_GOODBYE="Goodbye!"
  L_UNKNOWN_CMD="Unknown subcommand: %s"

  L_QSTATUS_TITLE="🐙 gh-manager · Quick status"
  L_QSTATUS_NO_AUTH="No accounts authenticated."
  L_QSTATUS_ACTIVE="Active account:"
  L_QSTATUS_ALL="Authenticated accounts:"

  L_HELP_USAGE="Usage:"
  L_HELP_MENU="Opens the interactive menu"
  L_HELP_STATUS="Shows the active account and full list"
  L_HELP_SWITCH="Interactive account switcher"
  L_HELP_SWITCH_USER="Switch directly to a specific account"
  L_HELP_VERSION="Show installed version"
  L_HELP_HELP="Show help"
  L_HELP_LANG="Override language (en|es|fr|de|pt|it)"

  L_MENU_WHAT="What would you like to do?"
  L_MENU_SECTION_ACCOUNTS="── Accounts ─────────────────────────────────"
  L_MENU_SECTION_TOOLS="── Tools ────────────────────────────────────"
  L_MENU_1="View detailed account status"
  L_MENU_2="Switch active account"
  L_MENU_3="Add new account"
  L_MENU_4="Log out of an account"
  L_MENU_5="View / copy account token"
  L_MENU_6="Check and refresh authentication"
  L_MENU_7="Assign account to directory (.envrc)"
  L_MENU_0="Exit"

  L_STATUS_TITLE="Account Status"
  L_STATUS_NO_ACCOUNTS="No accounts authenticated yet."
  L_STATUS_ADD_HINT="Go to ➕ Add new account to get started."
  L_STATUS_SCOPES="Scopes:"
  L_STATUS_FULL_OUTPUT="Full output of gh auth status:"

  L_SWITCH_TITLE="Switch active account"
  L_SWITCH_PICK="Which account do you want to switch to?"
  L_SWITCH_NOT_FOUND="Account %s is not authenticated."
  L_SWITCH_AVAILABLE="Available accounts:"
  L_SWITCH_ALREADY_ACTIVE="Account %s is already active."
  L_SWITCH_ACTIVATING="Activating %s..."
  L_SWITCH_SUCCESS="Account switched to %s!"
  L_SWITCH_ERROR="Could not switch account."

  L_ADD_TITLE="Add new account"
  L_ADD_INFO_1="The gh authentication flow will be launched."
  L_ADD_INFO_2="When the browser opens, sign in with the account you want to add."
  L_ADD_WARN_1="If you have multiple GitHub tabs open, make sure you are"
  L_ADD_WARN_2="signed in with the correct account before continuing."
  L_ADD_CONFIRM="Launch the authentication flow?"
  L_ADD_COMPLETE="Process completed."
  L_ADD_NOW_AUTH="Authenticated accounts:"

  L_LOGOUT_TITLE="Log out of an account"
  L_LOGOUT_PICK="Which account do you want to log out of?"
  L_LOGOUT_WARN_ACTIVE="%s is the currently active account."
  L_LOGOUT_WARN_ACTIVE_2="If you remove it, gh may be left without an active account."
  L_LOGOUT_CONFIRM="Log out of %s?"
  L_LOGOUT_LOGGING_OUT="Logging out of %s..."
  L_LOGOUT_SUCCESS="Logged out of %s."
  L_LOGOUT_ERROR="Could not log out."

  L_TOKEN_TITLE="Authentication token"
  L_TOKEN_PICK="Which account's token do you want to view?"
  L_TOKEN_SENSITIVE="Tokens are ${BOLD}sensitive credentials${RESET}. Do not share them."
  L_TOKEN_ACCOUNT="Account:"
  L_TOKEN_TOKEN="Token:"
  L_TOKEN_COPY="Copy token to clipboard? 📋"
  L_TOKEN_COPIED="Token copied to clipboard."

  L_REFRESH_TITLE="Check and refresh authentication"
  L_REFRESH_INFO="Verifies that all tokens are still valid against the GitHub API."
  L_REFRESH_NO_ACCOUNTS="No accounts authenticated."
  L_REFRESH_CHECKING="Checking %s..."
  L_REFRESH_VALID="Token valid"
  L_REFRESH_INVALID="Token invalid or expired"
  L_REFRESH_REAUTH="Re-authenticate %s now?"
  L_REFRESH_ALL_OK="All tokens are in order. 🎉"
  L_REFRESH_SOME_WARN="Some tokens may need renewal."

  L_ENVRC_TITLE="Assign account to directory (.envrc)"
  L_ENVRC_INFO_1="Creates or updates ${BOLD}.envrc${RESET} in the current directory."
  L_ENVRC_INFO_2="With ${BOLD}direnv${RESET}, the account activates automatically when you enter the directory."
  L_ENVRC_CWD="Current directory:"
  L_ENVRC_PICK="Which account do you want to assign to this directory?"
  L_ENVRC_UPDATING="Updating existing ${BOLD}.envrc${RESET}."
  L_ENVRC_CREATING="Creating new ${BOLD}.envrc${RESET}."
  L_ENVRC_OK="Added:  ${BOLD}export GH_USER=%s${RESET}  →  .envrc"
  L_ENVRC_DIRENV_RUN="Running ${BOLD}direnv allow${RESET}..."
  L_ENVRC_DIRENV_OK="direnv updated successfully."
  L_ENVRC_DIRENV_WARN="direnv is not installed."
  L_ENVRC_DIRENV_INSTALL="Install it with:  ${BOLD}brew install direnv${RESET}"
  L_ENVRC_DIRENV_HOOK="Add to your .zprofile:  ${BOLD}eval \"\$(direnv hook zsh)\"${RESET}"
}

